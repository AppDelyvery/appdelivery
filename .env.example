# APPDELYVERY — variáveis de ambiente. Copie para .env.local e preencha.
# .env.local é gitignored; este .env.example é versionado (sem segredos reais).

# Mapbox — token PÚBLICO restrito por URL (conta appdelivery). Vai pro client.
NEXT_PUBLIC_MAPBOX_TOKEN=

# Supabase — entra quando a conta dedicada existir.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Segredos SÓ server-side (nunca prefixar com NEXT_PUBLIC_):
SUPABASE_SERVICE_ROLE_KEY=
MAPBOX_SECRET_TOKEN=
ASAAS_API_KEY=
ASAAS_WEBHOOK_TOKEN=
FLAGCHECK_API_KEY=
INFOSIMPLES_TOKEN=
